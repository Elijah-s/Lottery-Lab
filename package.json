{
  "name": "lottery-lab",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "Local lottery analysis lab for SSQ and DLT (macOS native via Tauri).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "icons": "node scripts/gen-icons.mjs",
    "package:mac:arm": "tauri build --bundles dmg --target aarch64-apple-darwin",
    "package:mac:intel": "tauri build --bundles dmg --target x86_64-apple-darwin",
    "package:mac:universal": "tauri build --bundles dmg --target universal-apple-darwin",
    "package:windows": "tauri build --bundles nsis",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.56.2",
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-sql": "^2.4.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.454.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0",
    "@types/node": "^22.8.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.12.2",
    "@typescript-eslint/parser": "^8.12.2",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.14",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.9"
  }
}
